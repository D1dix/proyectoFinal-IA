{
  "name": "SUB - Guardar resolucion en Drive",
  "nodes": [
    {
      "parameters": {
        "inputSource": "passthrough"
      },
      "id": "f1111111-1111-1111-1111-111111111111",
      "name": "Recibe del agente",
      "type": "n8n-nodes-base.executeWorkflowTrigger",
      "typeVersion": 1.1,
      "position": [-200, 300]
    },
    {
      "parameters": {
        "operation": "toText",
        "sourceProperty": "contenido",
        "options": {
          "fileName": "resolucion.txt"
        }
      },
      "id": "f2222222-2222-2222-2222-222222222222",
      "name": "Texto a fichero",
