      "typeVersion": 1.1,
      "position": [40, 300]
    },
    {
      "parameters": {
        "name": "={{ $json.titulo || ('Resolucion_' + $now.format('yyyyLLdd_HHmmss')) }}",
        "driveId": {
          "__rl": true,
          "value": "My Drive",
          "mode": "list"
        },
        "folderId": {
          "__rl": true,
          "value": "PEGA_AQUI_EL_ID_DE_LA_CARPETA",
          "mode": "id"
        },
        "options": {
          "convertToGoogleDocument": true
        }
      },
      "id": "f3333333-3333-3333-3333-333333333333",
      "name": "Guardar en Drive (Doc)",
      "type": "n8n-nodes-base.googleDrive",
      "typeVersion": 3,
      "position": [280, 300]
    }
  ],
  "connections": {
    "Recibe del agente": {
      "main": [[{ "node": "Texto a fichero", "type": "main", "index": 0 }]]
    },
    "Texto a fichero": {
      "main": [[{ "node": "Guardar en Drive (Doc)", "type": "main", "index": 0 }]]
    }
  },
  "settings": { "executionOrder": "v1" },
